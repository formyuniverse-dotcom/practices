<!DOCTYPE html>

<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Я выбираю себя — 7-дневная практика</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --choco-dark:   #2A1A12;
    --choco-mid:    #3D2314;
    --choco-warm:   #5C3320;
    --choco-light:  #7A4A2E;
    --pink-soft:    #E8A4B0;
    --pink-mid:     #D4728A;
    --pink-light:   #F2C4CE;
    --pistachio:    #8FB89A;
    --pistachio-l:  #B5D4BC;
    --pistachio-d:  #5A8C68;
    --white:        #FFFFFF;
    --white-70:     rgba(255,255,255,0.7);
    --white-40:     rgba(255,255,255,0.4);
    --white-15:     rgba(255,255,255,0.15);
    --white-08:     rgba(255,255,255,0.08);
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
background: var(–choco-dark);
color: var(–white);
font-family: ‘Jost’, sans-serif;
font-weight: 300;
min-height: 100vh;
overflow-x: hidden;
}

/* Grain texture */
body::after {
content: ‘’;
position: fixed;
inset: 0;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 512 512’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘n’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.75’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23n)’ opacity=‘0.06’/%3E%3C/svg%3E”);
pointer-events: none;
z-index: 999;
}

/* Progress bar */
.progress-bar {
position: fixed;
top: 0; left: 0;
height: 2px;
background: linear-gradient(90deg, var(–pink-mid), var(–pistachio));
transition: width 0.5s ease;
z-index: 100;
width: 0%;
}

/* ── COVER PAGE ── */
.cover {
min-height: 100vh;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
position: relative;
overflow: hidden;
padding: 60px 24px;
}

/* Gradient blobs */
.cover::before {
content: ‘’;
position: absolute;
width: 600px; height: 600px;
background: radial-gradient(circle, rgba(232,164,176,0.18) 0%, transparent 70%);
top: -100px; right: -150px;
border-radius: 50%;
animation: float1 8s ease-in-out infinite;
}

.cover::after {
content: ‘’;
position: absolute;
width: 500px; height: 500px;
background: radial-gradient(circle, rgba(143,184,154,0.14) 0%, transparent 70%);
bottom: -80px; left: -120px;
border-radius: 50%;
animation: float2 10s ease-in-out infinite;
}

@keyframes float1 {
0%,100% { transform: translate(0,0) scale(1); }
50% { transform: translate(-30px, 40px) scale(1.05); }
}
@keyframes float2 {
0%,100% { transform: translate(0,0) scale(1); }
50% { transform: translate(40px, -30px) scale(1.08); }
}

.cover-inner {
position: relative;
z-index: 2;
text-align: center;
max-width: 480px;
}

/* Lotus SVG illustration */
.lotus-wrap {
margin-bottom: 36px;
animation: fadeDown 1.2s ease both;
}

.lotus-svg {
width: 120px;
height: 120px;
filter: drop-shadow(0 0 30px rgba(232,164,176,0.4));
}

.cover-tag {
font-size: 10px;
letter-spacing: 4px;
text-transform: uppercase;
color: var(–pistachio-l);
margin-bottom: 20px;
animation: fadeUp 1s ease 0.3s both;
}

.cover-title {
font-family: ‘Cormorant Garamond’, serif;
font-size: clamp(42px, 10vw, 72px);
font-weight: 300;
line-height: 1.05;
margin-bottom: 6px;
animation: fadeUp 1s ease 0.5s both;
}

.cover-title em {
font-style: italic;
color: var(–pink-soft);
display: block;
}

.cover-sub {
font-size: 12px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–white-40);
margin-top: 20px;
animation: fadeUp 1s ease 0.7s both;
}

.cover-divider {
width: 60px;
height: 1px;
background: linear-gradient(90deg, transparent, var(–pink-mid), transparent);
margin: 28px auto;
animation: fadeUp 1s ease 0.9s both;
}

.cover-desc {
font-family: ‘Cormorant Garamond’, serif;
font-size: 18px;
font-style: italic;
color: var(–white-70);
line-height: 1.7;
animation: fadeUp 1s ease 1.1s both;
}

.scroll-hint {
position: absolute;
bottom: 40px;
left: 50%;
transform: translateX(-50%);
display: flex;
flex-direction: column;
align-items: center;
gap: 8px;
font-size: 10px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–white-40);
animation: fadeUp 1s ease 1.5s both;
cursor: pointer;
}

.scroll-arrow {
width: 1px;
height: 40px;
background: linear-gradient(to bottom, var(–white-40), transparent);
animation: scrollPulse 2s ease-in-out infinite;
}

@keyframes scrollPulse {
0%,100% { opacity: 0.4; transform: scaleY(1); }
50% { opacity: 1; transform: scaleY(1.2); }
}

/* ── MAIN CONTENT ── */
.main {
max-width: 680px;
margin: 0 auto;
padding: 80px 24px 100px;
}

/* Section header */
.section-intro {
text-align: center;
margin-bottom: 64px;
animation: fadeUp 1s ease both;
}

.section-intro .tag {
font-size: 10px;
letter-spacing: 4px;
text-transform: uppercase;
color: var(–pistachio);
margin-bottom: 16px;
}

.section-intro h2 {
font-family: ‘Cormorant Garamond’, serif;
font-size: 28px;
font-weight: 300;
font-style: italic;
color: var(–white-70);
line-height: 1.5;
}

/* Practice blocks */
.block {
margin-bottom: 48px;
animation: fadeUp 0.8s ease both;
}

.block:nth-child(1) { animation-delay: 0.1s; }
.block:nth-child(2) { animation-delay: 0.25s; }
.block:nth-child(3) { animation-delay: 0.4s; }

.block-header {
display: flex;
align-items: flex-start;
gap: 20px;
margin-bottom: 20px;
}

.block-num {
font-family: ‘Cormorant Garamond’, serif;
font-size: 52px;
font-weight: 300;
line-height: 1;
color: var(–white-15);
min-width: 40px;
}

.block-meta { flex: 1; padding-top: 6px; }

.block-label {
font-size: 9px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–pink-soft);
margin-bottom: 5px;
}

.block-title {
font-family: ‘Cormorant Garamond’, serif;
font-size: 24px;
font-weight: 400;
font-style: italic;
color: var(–white);
}

.block-line {
height: 1px;
background: linear-gradient(90deg, var(–pink-mid), var(–pistachio-d), transparent);
margin-bottom: 24px;
opacity: 0.5;
}

.practice-card {
background: var(–white-08);
border: 1px solid var(–white-15);
border-radius: 20px;
padding: 32px;
backdrop-filter: blur(10px);
position: relative;
overflow: hidden;
}

.practice-card::before {
content: ‘’;
position: absolute;
top: 0; left: 0;
width: 3px; height: 100%;
}

.block:nth-child(1) .practice-card::before { background: linear-gradient(to bottom, var(–pink-mid), transparent); }
.block:nth-child(2) .practice-card::before { background: linear-gradient(to bottom, var(–pistachio), transparent); }
.block:nth-child(3) .practice-card::before { background: linear-gradient(to bottom, var(–pink-soft), var(–pistachio)); }

.practice-card p {
font-family: ‘Cormorant Garamond’, serif;
font-size: 19px;
line-height: 1.9;
color: var(–white-70);
margin-bottom: 16px;
}

.practice-card p:last-of-type { margin-bottom: 0; }

.practice-card p em {
color: var(–pink-light);
font-style: italic;
}

.practice-card p strong {
color: var(–white);
font-weight: 400;
}

.breath-note {
display: flex;
align-items: center;
gap: 12px;
margin-top: 24px;
padding-top: 20px;
border-top: 1px solid var(–white-15);
font-size: 11px;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–pistachio-l);
}

/* Quote */
.quote-wrap {
text-align: center;
padding: 56px 16px;
position: relative;
margin: 16px 0;
}

.quote-wrap::before, .quote-wrap::after {
content: ‘’;
position: absolute;
left: 50%; transform: translateX(-50%);
width: 1px; height: 40px;
background: linear-gradient(to bottom, transparent, var(–pink-mid));
}
.quote-wrap::before { top: 0; }
.quote-wrap::after {
bottom: 0;
background: linear-gradient(to bottom, var(–pink-mid), transparent);
}

.quote-wrap blockquote {
font-family: ‘Cormorant Garamond’, serif;
font-size: clamp(20px, 4vw, 28px);
font-style: italic;
font-weight: 300;
color: var(–pink-soft);
line-height: 1.6;
max-width: 520px;
margin: 0 auto;
}

/* Diary */
.diary-section { margin-top: 64px; }

.diary-header {
text-align: center;
margin-bottom: 40px;
}

.diary-header .tag {
font-size: 10px;
letter-spacing: 4px;
text-transform: uppercase;
color: var(–pistachio);
margin-bottom: 14px;
}

.diary-header h2 {
font-family: ‘Cormorant Garamond’, serif;
font-size: 32px;
font-weight: 300;
font-style: italic;
color: var(–white);
}

.diary-day {
background: var(–white-08);
border: 1px solid var(–white-15);
border-radius: 16px;
padding: 28px;
margin-bottom: 14px;
transition: all 0.3s ease;
position: relative;
overflow: hidden;
}

.diary-day::before {
content: ‘’;
position: absolute;
top: 0; left: 0;
width: 100%; height: 2px;
background: linear-gradient(90deg, var(–pink-mid), var(–pistachio));
opacity: 0;
transition: opacity 0.3s;
}

.diary-day:focus-within {
border-color: rgba(232,164,176,0.4);
background: rgba(255,255,255,0.06);
}

.diary-day:focus-within::before { opacity: 1; }

.diary-day-top {
display: flex;
justify-content: space-between;
align-items: baseline;
margin-bottom: 12px;
}

.day-label {
font-size: 10px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–pink-soft);
}

.day-counter {
font-size: 11px;
color: var(–white-40);
}

.day-question {
font-family: ‘Cormorant Garamond’, serif;
font-size: 17px;
font-style: italic;
color: var(–white-70);
margin-bottom: 14px;
line-height: 1.5;
}

.diary-input {
width: 100%;
background: transparent;
border: none;
border-bottom: 1px solid var(–white-15);
color: var(–white);
font-family: ‘Jost’, sans-serif;
font-weight: 300;
font-size: 15px;
line-height: 1.7;
padding: 8px 0;
outline: none;
resize: none;
min-height: 72px;
transition: border-color 0.3s;
caret-color: var(–pink-soft);
}

.diary-input::placeholder {
color: var(–white-40);
font-style: italic;
}

.diary-input:focus { border-bottom-color: var(–pink-soft); }

/* Save button */
.save-btn {
width: 100%;
margin-top: 40px;
padding: 20px;
background: linear-gradient(135deg, var(–choco-warm), var(–choco-light));
border: 1px solid rgba(232,164,176,0.3);
border-radius: 50px;
color: var(–white);
font-family: ‘Jost’, sans-serif;
font-size: 11px;
font-weight: 400;
letter-spacing: 3px;
text-transform: uppercase;
cursor: pointer;
display: flex;
align-items: center;
justify-content: center;
gap: 12px;
transition: all 0.3s ease;
}

.save-btn:hover {
background: linear-gradient(135deg, var(–pink-mid), var(–pistachio-d));
border-color: transparent;
transform: translateY(-2px);
box-shadow: 0 12px 32px rgba(212,114,138,0.3);
}

/* Closing */
.closing {
text-align: center;
margin-top: 80px;
padding-top: 56px;
border-top: 1px solid var(–white-15);
}

.lotus-small {
width: 48px;
height: 48px;
margin: 0 auto 24px;
opacity: 0.5;
filter: drop-shadow(0 0 12px rgba(232,164,176,0.4));
}

.closing p {
font-family: ‘Cormorant Garamond’, serif;
font-size: 18px;
font-style: italic;
color: var(–white-70);
line-height: 1.8;
max-width: 420px;
margin: 0 auto 10px;
}

.author {
margin-top: 28px;
font-size: 10px;
letter-spacing: 4px;
text-transform: uppercase;
color: var(–pistachio-l);
}

/* Toast */
.toast {
position: fixed;
bottom: 32px; left: 50%;
transform: translateX(-50%) translateY(120px);
background: linear-gradient(135deg, var(–choco-warm), var(–choco-light));
border: 1px solid rgba(232,164,176,0.3);
color: var(–white);
padding: 16px 32px;
border-radius: 50px;
font-size: 12px;
letter-spacing: 2px;
text-transform: uppercase;
transition: transform 0.5s cubic-bezier(0.34,1.56,0.64,1);
z-index: 200;
white-space: nowrap;
box-shadow: 0 8px 32px rgba(0,0,0,0.4);
}

.toast.show { transform: translateX(-50%) translateY(0); }

@keyframes fadeUp {
from { opacity: 0; transform: translateY(28px); }
to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeDown {
from { opacity: 0; transform: translateY(-20px); }
to   { opacity: 1; transform: translateY(0); }
}

@media (max-width: 480px) {
.main { padding: 60px 20px 80px; }
.practice-card { padding: 24px 20px; }
.diary-day { padding: 22px 18px; }
}
</style>

</head>
