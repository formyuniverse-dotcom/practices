});

// Auto-save + progress
days.forEach((_, i) => {
const el = document.getElementById(`inp_${i}`);
if (!el) return;
el.addEventListener(‘input’, () => {
try { localStorage.setItem(`practice_day_${i}`, el.value); } catch(e){}
updateProgress();
});
});

function updateProgress() {
const filled = days.filter((_,i) => {
const el = document.getElementById(`inp_${i}`);
return el && el.value.trim().length > 0;
}).length;
document.getElementById(‘progressBar’).style.width = (filled / days.length * 100) + ‘%’;
}

function saveAll() {
let count = 0;
days.forEach((_,i) => {
const el = document.getElementById(`inp_${i}`);
if (el && el.value.trim()) {
try { localStorage.setItem(`practice_day_${i}`, el.value); } catch(e){}
count++;
}
});
const t = document.getElementById(‘toast’);
t.textContent = count > 0 ? `Сохранено ${count} ${count===1?'запись':'записей'} ✦` : ‘Всё сохранено ✦’;
t.classList.add(‘show’);
setTimeout(() => t.classList.remove(‘show’), 3000);
}

updateProgress();
</script>

